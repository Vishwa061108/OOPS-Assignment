#include <iostream>
using namespace std;

// Abstract Base Class
class Shape {
protected:
    float dim1, dim2;

public:
    Shape(float a, float b) {
        dim1 = a;
        dim2 = b;
    }

    // Pure Virtual Function
    virtual float area() = 0;

    // Normal Function
    void display() {
        cout << "Dimensions: " << dim1 << ", " << dim2 << endl;
    }
};

// Derived Class 1
class Rectangle : public Shape {
public:
    Rectangle(float a, float b) : Shape(a, b) {}

    float area() {
        return dim1 * dim2;
    }
};

// Derived Class 2
class Triangle : public Shape {
public:
    Triangle(float a, float b) : Shape(a, b) {}

    float area() {
        return 0.5 * dim1 * dim2;
    }
};

